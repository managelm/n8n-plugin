{
  "name": "n8n-nodes-managelm",
  "version": "1.0.1",
  "description": "n8n community node for ManageLM — manage Linux servers, run tasks, and monitor infrastructure from n8n workflows.",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "managelm",
    "server-management",
    "linux",
    "infrastructure",
    "devops"
  ],
  "license": "MIT",
  "homepage": "https://www.managelm.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/managelm/n8n-plugin.git"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "lint": "eslint nodes credentials --ext .ts",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/ManageLmApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/ManageLm/ManageLm.node.js",
      "dist/nodes/ManageLm/ManageLmTrigger.node.js"
    ]
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "gulp": "^4.0.2",
    "n8n-workflow": "^1.0.0",
    "typescript": "^5.3.0"
  },
  "peerDependencies": {
    "n8n-workflow": ">=1.0.0"
  }
}
